---
layout: null
---
[{%- for post in site.posts %}{%- capture clean_content -%}{% assign parts = post.content | split: '<pre' %}{% for part in parts %}{% if forloop.first %}{{ part }}{% else %}{{ part | split: '</pre>' | last }}{% endif %}{% endfor %}{%- endcapture -%}
{
"title": {{ post.title | jsonify }},
"url": "{{ post.url | prepend: site.baseurl }}",
"content": {{ clean_content | strip_html | strip_urls | strip | jsonify }},
"categories": {{ post.categories | jsonify }},
"date": "{{ post.date | date: '%Y-%m-%d' }}"
}{%- unless forloop.last %},{% endunless %}{% endfor %}
]
